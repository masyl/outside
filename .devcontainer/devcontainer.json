{
    "name": "Outside Development (Node 22)",
    "image": "mcr.microsoft.com/devcontainers/typescript-node:1-22-bullseye",
    "features": {
        "ghcr.io/devcontainers/features/node:1": {
            "version": "22",
            "pnpm": "latest"
        },
        "ghcr.io/devcontainers/features/docker-outside-of-docker:1": {}
    },
    "customizations": {
        "vscode": {
            "settings": {
                "files.eol": "\n",
                "editor.formatOnSave": true,
                "editor.defaultFormatter": "esbenp.prettier-vscode"
            },
            "extensions": [
                "dbaeumer.vscode-eslint",
                "esbenp.prettier-vscode",
                "ms-playwright.playwright"
            ]
        }
    },
    "forwardPorts": [
        5173,
        6006
    ],
    "postCreateCommand": "pnpm install",
    "remoteUser": "node",
    "initializeCommand": "docker network create outside-proxy || true",
    "runArgs": [
        "--network=outside-proxy",
        "--label=caddy_0=storybook.devops.outside.localhost",
        "--label=caddy_0.reverse_proxy={{upstreams 6007}}",
        "--label=caddy_1=client.devops.outside.localhost",
        "--label=caddy_1.reverse_proxy={{upstreams 5173}}"
    ]
}